        },
        {
          "@type": "cr:Field",
          "@id": "experiments/exp",
          "name": "exp",
          "description": "Experiment number within the run (e.g., exp0 is baseline)",
          "dataType": "sc:Text",
          "source": {
            "fileObject": { "@id": "experiments-parquet" },
            "extract": { "column": "exp" }
          }
        },
        {
          "@type": "cr:Field",
