          "name": "status",
          "description": "Experiment outcome: baseline, keep (improved), discard (worse), or crash",
          "dataType": "sc:Text",
          "source": {
            "fileObject": { "@id": "experiments-parquet" },
            "extract": { "column": "status" }
          }
        },
