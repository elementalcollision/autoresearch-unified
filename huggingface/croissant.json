          "@id": "experiments/peak_mem_gb",
          "name": "peak_mem_gb",
          "description": "Peak GPU memory usage in gigabytes during training",
          "dataType": "sc:Float",
          "source": {
            "fileObject": { "@id": "experiments-parquet" },
            "extract": { "column": "peak_mem_gb" }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "experiments/tok_sec",
