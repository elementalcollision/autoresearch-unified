  "@type": "sc:Dataset",
  "conformsTo": "http://mlcommons.org/croissant/1.1",
  "name": "autoresearch-experiments",
  "description": "Cross-platform hyperparameter optimization experiments from autonomous LLM-driven ML research. An LLM agent (Claude Sonnet) autonomously proposes hyperparameter modifications, trains a small language model for 5 minutes, evaluates validation bits-per-byte (val_bpb), and iterates. Experiments span Apple Metal (M5 Max), NVIDIA CUDA (RTX 4000 Ada, A100 40GB, RTX Pro 6000 Blackwell), and AMD ROCm (MI300X) hardware platforms across 7 text datasets.",
  "license": "https://creativecommons.org/licenses/by/4.0/",
  "url": "https://huggingface.co/datasets/davegraham/autoresearch-experiments",
  "creator": {
    "@type": "sc:Organization",
    "name": "elementalcollision",
    "url": "https://github.com/elementalcollision"
  },
  "datePublished": "2026-03-23",
  "dateModified": "2026-03-23",
  "version": "1.0.0",
  "inLanguage": "en",
  "keywords": [
    "hyperparameter-optimization",
    "autonomous-research",
    "LLM-agent",
    "GPU-benchmarks",
    "cross-platform",
    "Apple-Metal",
    "NVIDIA-CUDA",
    "AMD-ROCm",
    "language-model-training",
    "val_bpb"
  ],
  "citeAs": "@dataset{autoresearch_experiments_2026, title={Autoresearch Cross-Platform Experiments}, author={elementalcollision}, year={2026}, url={https://huggingface.co/datasets/davegraham/autoresearch-experiments}, license={CC-BY-4.0}}",
  "distribution": [
    {
      "@type": "cr:FileObject",
      "@id": "experiments-parquet",
      "name": "experiments.parquet",
      "description": "Unified experiment results across all hardware platforms, GPUs, and datasets",
      "contentUrl": "data/experiments.parquet",
      "encodingFormat": "application/x-parquet",
      "contentSize": "172 KB",
      "sha256": "e251ddbe03f9b0cb675ef9ada5066e8c2ad010f04ca333f0f010ac295f259e1d"
    },
    {
      "@type": "cr:FileObject",
      "@id": "hardware-parquet",
      "name": "hardware.parquet",
      "description": "Hardware specifications reference table for all GPUs tested",
      "contentUrl": "data/hardware.parquet",
      "encodingFormat": "application/x-parquet",
      "contentSize": "7 KB",
      "sha256": "f5f1b038ed26ccd800e4e992fc489f45a33af4810851fa9c0482c2a1f7285bba"
    }
  ],
  "recordSet": [
    {
      "@type": "cr:RecordSet",
      "@id": "experiments",
      "name": "experiments",
