          "source": {
            "fileObject": { "@id": "experiments-parquet" },
            "extract": { "column": "gpu_provider" }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "experiments/dataset",
          "name": "dataset",
          "description": "Training dataset name (e.g., climbmix, fineweb-edu, cosmopedia-v2)",
          "dataType": "sc:Text",
          "source": {
            "fileObject": { "@id": "experiments-parquet" },
            "extract": { "column": "dataset" }
