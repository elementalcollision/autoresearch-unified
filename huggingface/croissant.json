      "key": { "@id": "experiments/experiment_id" },
      "field": [
        {
          "@type": "cr:Field",
          "@id": "experiments/experiment_id",
          "name": "experiment_id",
          "description": "Globally unique identifier: {platform}_{gpu}_{dataset}_{run_id}_{exp}",
          "dataType": "sc:Text",
          "source": {
            "fileObject": { "@id": "experiments-parquet" },
            "extract": { "column": "experiment_id" }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "experiments/platform",
          "name": "platform",
          "description": "Hardware platform: apple_metal, nvidia_cuda, or amd_rocm",
          "dataType": "sc:Text",
          "source": {
            "fileObject": { "@id": "experiments-parquet" },
            "extract": { "column": "platform" }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "experiments/gpu_name",
          "name": "gpu_name",
          "description": "GPU model name (e.g., M5 Max, RTX 4000 Ada, A100 40GB, MI300X)",
          "dataType": "sc:Text",
          "source": {
            "fileObject": { "@id": "experiments-parquet" },
            "extract": { "column": "gpu_name" }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "experiments/gpu_provider",
          "name": "gpu_provider",
          "description": "Cloud provider or local: digitalocean, vultr, runpod, local",
