          "name": "steps",
          "description": "Number of training steps completed in the 5-minute budget",
          "dataType": "sc:Integer",
          "source": {
            "fileObject": { "@id": "experiments-parquet" },
            "extract": { "column": "steps" }
          }
        },
        {
          "@type": "cr:Field",
